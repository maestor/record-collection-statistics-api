# Discogs API configuration for import data
DISCOGS_ACCESS_TOKEN=your_discogs_personal_access_token_here
DISCOGS_USER_AGENT=record-collection-statistics-api/0.1 (+local)
DISCOGS_RELEASE_TTL_DAYS=30
DISCOGS_MIN_INTERVAL_MS=1100

# Turso remote database configuration
USE_REMOTE_DB=false
TURSO_DATABASE_URL=your_turso_database_url_here
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# General application configuration
DATABASE_PATH=var/discogs.sqlite
PORT=3000

# API key for external access (leave empty or remove for no authentication)
API_READ_KEY=your_api_key_here



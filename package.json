{
  "name": "record-collection-statistics-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first Discogs collection importer and read-only statistics API.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node --watch --import tsx src/server.ts",
    "db:migrate": "node --import tsx src/cli/db-migrate.ts",
    "db:copy-to-remote": "node --import tsx src/cli/db-copy-to-remote.ts",
    "import:discogs": "node --import tsx src/cli/import-discogs.ts",
    "test": "node --import tsx --test",
    "test:coverage": "node --import tsx --test --experimental-test-coverage",
    "test:mutation": "stryker run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "verify": "npm run typecheck && npm run lint && npm run test:coverage"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@libsql/client": "^0.17.3",
    "dotenv": "^17.4.2",
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/tap-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
